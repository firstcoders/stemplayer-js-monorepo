{
  "name": "@firstcoders/element-styles",
  "description": "Webcomponent element-styles following open-wc recommendations",
  "license": "MIT",
  "author": "element-styles",
  "version": "1.0.1-beta.0",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "exports": {
    ".": "./index.js",
    "./grid.js": "./src/grid.js",
    "./spacing.js": "./src/spacing.js",
    "./row.js": "./src/row.js",
    "./flex.js": "./src/flex.js",
    "./animate.js": "./src/animate.js"
  },
  "scripts": {
    "lint": "eslint . && prettier \"**/*.js\" --check --ignore-path .gitignore",
    "format": "eslint . --fix && prettier \"**/*.js\" --write --ignore-path .gitignore"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@open-wc/eslint-config": "^13.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
